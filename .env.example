# JMF 509 Warehouse - Database configuration
# Copy this file to .env and set your values

# MySQL (default for PHP app)
DB_HOST=localhost
DB_NAME=jmf509_warehouse
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# PostgreSQL + PostgREST (optional - use with docker compose)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=jmf509_warehouse
# POSTGRES_USER=postgres
# POSTGRES_PASS=postgres
# POSTGREST_URL=http://localhost:3000

# Email (optional). Set MAIL_ENABLED=1 to send real email via PHP mail(); otherwise only logged.
# MAIL_FROM_EMAIL and MAIL_FROM_NAME used as From header. For SMTP use your server's sendmail or an external service.
# MAIL_ENABLED=0
# MAIL_FROM_EMAIL=noreply@jmf509.com
# MAIL_FROM_NAME=JMF 509 Warehouse
